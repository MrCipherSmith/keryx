{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keryx.local/schemas/mask-resolution.schema.json",
  "title": "Resolved credential mask set",
  "description": "Ephemeral result of resolveCredentialMasks. Must never include real secret values.",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "masks", "tlsTerminate", "tlsSource", "notes"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["auto", "manual", "off"]
    },
    "masks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "injectHosts", "source"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Environment variable name (e.g. DEEPSEEK_API_KEY)."
          },
          "injectHosts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "source": {
            "type": "string",
            "enum": ["auto", "explicit", "merged"]
          }
        }
      }
    },
    "tlsTerminate": { "type": "boolean" },
    "tlsSource": {
      "type": "string",
      "enum": ["env", "flag", "auto-derived", "defaults", "off"]
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-secret diagnostic messages."
    }
  }
}
